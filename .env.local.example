# Local Development Overrides
# Copy this file to .env.local and fill in your values

# Database
NEON_DATABASE=postgresql://user:password@host.neon.tech/db?sslmode=require

# Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=change_this_to_secure_random_32_chars
AUTH_SECRET=change_this_to_secure_random_32_chars

# Admin key for protected endpoints (generate with: openssl rand -hex 16)
ADMIN_KEY=change_this_to_secure_admin_key

# PayPal (use 'test' for sandbox)
PAYPAL_CLIENT_ID=test
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Environment
NODE_ENV=development
